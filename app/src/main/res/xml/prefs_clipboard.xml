<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <SwitchPreferenceCompat
            android:key="clipboard_suggest"
            android:title="@string/pref_clipboard_title"
            android:summary="@string/pref_clipboard_summary"
            android:defaultValue="true" />

    <ListPreference
        android:key="clip_timeout"
        android:icon="@drawable/ic_pref_clipboard"
        android:title="@string/pref_clip_timeout_title"
        android:entries="@array/clip_timeout_entries"
        android:entryValues="@array/clip_timeout_values"
        android:defaultValue="0"
        app:useSimpleSummaryProvider="true" />

</PreferenceScreen>
